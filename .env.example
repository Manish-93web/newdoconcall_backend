NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/<dbname>?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=30d

# Google Maps (server-side geocoding) — restrict this key to your server IP in Google Cloud Console
GOOGLE_MAPS_SERVER_KEY=

# Google OAuth (social login) — leave blank until you create an OAuth app; /auth/google will respond "not configured"
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Notifications: console | (future) twilio | sendgrid | fcm
NOTIFICATION_PROVIDER=console

# File storage: local | (future) s3
UPLOAD_STORAGE_PROVIDER=local

# CORS — comma-separated origins allowed to call the API / open sockets
CORS_ORIGINS=http://localhost:3000
SOCKET_CORS_ORIGINS=http://localhost:3000

# Public base URL of this API (used in generated links, e.g. file URLs)
API_BASE_URL=http://localhost:5000
