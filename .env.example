NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/<dbname>?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=30d

# Google Maps (server-side geocoding) — restrict this key to your server IP in Google Cloud Console
GOOGLE_MAPS_SERVER_KEY=

# AI symptom checker (Claude API). Leave blank to keep the deterministic keyword-matching
# heuristic; set this to switch /ai/symptom-check to real LLM-based triage.
ANTHROPIC_API_KEY=

# Google OAuth (social login). The web/mobile clients obtain a signed ID token directly
# from Google (Google Identity Services JS / native Sign-In SDK) and POST it to
# /auth/google, which verifies it against this client ID — no client secret needed.
# Leave CLIENT_ID blank until you create an OAuth app; /auth/google will respond "not configured".
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Sign in with Apple. The web/mobile clients obtain a signed identity token directly
# from Apple (Apple JS SDK / native Sign in with Apple) and POST it to /auth/apple,
# which verifies it against these values — no private key needed for verification alone.
# CLIENT_ID = your Services ID (Certificates, Identifiers & Profiles > Identifiers > Services IDs).
# BUNDLE_ID = your iOS app's bundle identifier. Leave both blank; /auth/apple will respond
# "not configured" until you create these in the Apple Developer portal.
APPLE_CLIENT_ID=
APPLE_BUNDLE_ID=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# WebRTC ICE servers for telemedicine calls. STUN alone works on simple networks;
# without TURN, calls fail behind symmetric NATs/restrictive firewalls. Leave blank to
# fall back to a public Google STUN server. To self-host TURN, deploy infra/coturn/ on a
# Linux host with a public IP and fill these in with matching values (see that folder).
STUN_URLS=
TURN_URLS=
TURN_STATIC_SECRET=

# Notifications. Each channel activates independently as soon as its own credentials
# below are set — leave any of them blank to keep that channel logging to the console.
NOTIFICATION_PROVIDER=console

# SMS (Twilio) — leave blank to log SMS to the console instead
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# WhatsApp (Twilio) — a separate, WhatsApp-enabled sender (e.g. the Twilio sandbox
# number while testing), NOT the same number as TWILIO_FROM_NUMBER above. Reuses
# TWILIO_ACCOUNT_SID/TWILIO_AUTH_TOKEN. Leave blank to log WhatsApp messages to the console.
TWILIO_WHATSAPP_FROM=

# Android SMS Retriever API app hash, appended to outgoing OTP SMS bodies so the mobile
# app can auto-read the code. Leave blank to skip appending (manual OTP entry still works).
SMS_APP_HASH=

# Domain the web frontend is served from (e.g. doconcall.com — no protocol/path), used to
# bind OTP SMS to that origin for the WebOTP API so the web login/register OTP screen can
# auto-read the code. Leave blank to skip (manual OTP entry still works). Only applies to
# OTP requests made with platform: "web"; mobile requests keep using SMS_APP_HASH above.
WEBOTP_DOMAIN=

# Email (SendGrid) — leave blank to log emails to the console instead
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Push (Firebase Cloud Messaging) — paste the full service account JSON as one line,
# leave blank to log push notifications to the console instead
FIREBASE_SERVICE_ACCOUNT_JSON=

# File storage: local | (future) s3
UPLOAD_STORAGE_PROVIDER=local

# CORS — comma-separated origins allowed to call the API / open sockets
CORS_ORIGINS=http://localhost:3000
SOCKET_CORS_ORIGINS=http://localhost:3000

# Public base URL of this API (used in generated links, e.g. file URLs)
API_BASE_URL=http://localhost:5000
